# .env.example
# --- Local Postgres (Docker Compose) ---
POSTGRES_USER=bcbg
POSTGRES_PASSWORD=bcbg_dev_password
POSTGRES_DB=bcbg_dev
POSTGRES_PORT=5432

# --- Prisma ---
# Matches the values above. Used by `prisma migrate`, `prisma studio`, and the app itself.
DATABASE_URL="postgresql://bcbg:bcbg_dev_password@localhost:5432/bcbg_dev"

# --- Clerk (added in Step 2) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
CLERK_WEBHOOK_SIGNING_SECRET=

# --- Stripe (added in Step 6/7) ---
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# --- Resend / Twilio (added in Step 7) ---
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=